{
  "name": "loyalty-be",
  "version": "1.0.0",
  "description": "Loyalty backend - NestJS API with Supabase email/OTP auth",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prestart": "node -e \"require('fs').accessSync('dist/main.js')\"",
    "start": "node dist/main.js",
    "render:build": "NODE_ENV=development npm install && npm run build",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint \"src/**/*.{ts,js}\" --max-warnings=0",
    "test": "echo \"No tests configured\" && exit 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "@supabase/supabase-js": "^2.48.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
